{
    "dataRoles": [
        {
            "displayName": "Record Key",
            "name": "recordKey",
            "kind": "Grouping",
            "description": "Optional: drag a field here to show different content per value (e.g. project names, regions)"
        }
    ],
    "objects": {
        "fabricConfig": {
            "displayName": "Fabric Configuration",
            "properties": {
                "workspaceId": {
                    "type": { "text": true }
                },
                "functionSetId": {
                    "type": { "text": true }
                },
                "visualId": {
                    "type": { "text": true }
                }
            }
        },
        "viewConfig": {
            "displayName": "View",
            "properties": {
                "readOnly": {
                    "type": { "bool": true }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "for": {
                        "in": "recordKey"
                    },
                    "dataReductionAlgorithm": {
                        "top": { "count": 1 }
                    }
                }
            }
        }
    ],
    "privileges": [
        {
            "name": "WebAccess",
            "essential": true,
            "parameters": ["https://*"]
        },
        {
            "name": "AADAuthentication",
            "essential": true,
            "parameters": ["https://api.fabric.microsoft.com"]
        }
    ]
}
